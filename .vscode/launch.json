{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "F5: debug current C file (gcc/gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "avoidWindowsConsoleRedirection": false,
            "internalConsoleOptions": "neverOpen",
            "MIMode": "gdb",
            "miDebuggerPath": "D:\\VS code\\mingw64\\bin\\gdb.exe",
            "preLaunchTask": "C: build active file (gcc)",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Run fall detection web app (Python 3.12)",
            "type": "debugpy",
            "request": "launch",
            "program": "C:\\Users\\20207\\Desktop\\人工智能创新大赛+自动化学院+闵羽帆\\fall_detection\\web_app.py",
            "python": "D:\\python\\python.exe",
            "cwd": "C:\\Users\\20207\\Desktop\\人工智能创新大赛+自动化学院+闵羽帆\\fall_detection",
            "console": "integratedTerminal",
            "env": {
                "PYTHONUTF8": "1",
                "PYTHONUNBUFFERED": "1"
            },
            "justMyCode": true
        }
    ]
}
